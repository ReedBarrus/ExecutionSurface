{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dme/language-kernel/export_receipt.schema.json",
    "title": "DME Language Kernel Export Receipt v0",
    "description": "Schema for a bounded export receipt recording what structural material was exposed to the DME Language Kernel. This is an upstream audit artifact only. It carries no structural, memory, identity, canon, or truth authority by itself.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "export_receipt_id",
        "exporter_version",
        "kernel_contract_version",
        "export_packet_id",
        "source_run_id",
        "source_csv_path",
        "source_csv_sha256",
        "declared_lens",
        "support_tier",
        "query_class",
        "claim_class_ceiling",
        "legal_posture",
        "allowed_uses",
        "export_scope",
        "row_count",
        "object_handles",
        "receipt_hashes",
        "overall_status",
        "exported_at"
    ],
    "properties": {
        "export_receipt_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^ER:[A-Za-z0-9._:-]+$",
            "description": "Unique identifier for this export receipt."
        },
        "exporter_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the exporter that produced this receipt."
        },
        "kernel_contract_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the Language Kernel contract governing this export."
        },
        "export_packet_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^EK:[A-Za-z0-9._:-]+$",
            "description": "Identifier of the bounded export packet produced by the exporter."
        },
        "source_run_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Source run id from which structural material was exported."
        },
        "source_csv_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024,
            "description": "Path to the source csv used to produce the export packet."
        },
        "source_csv_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "SHA-256 hash of the source csv used to produce the export packet."
        },
        "source_jsonl_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024,
            "description": "Optional path to a companion source jsonl file."
        },
        "source_jsonl_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "Optional SHA-256 hash of the companion source jsonl file."
        },
        "declared_lens": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "description": "Declared lens under which the export packet was formed."
        },
        "support_tier": {
            "type": "string",
            "enum": [
                "Tier 0 live runtime",
                "RETAINED_ONLY",
                "INSUFFICIENT_TIER"
            ],
            "description": "Support-tier posture of the export."
        },
        "query_class": {
            "type": "string",
            "enum": [
                "Q3",
                "Q4",
                "Q6",
                "Q7"
            ],
            "description": "Active bounded query class governing the export packet."
        },
        "claim_class_ceiling": {
            "type": "string",
            "enum": [
                "L1",
                "L2",
                "L4",
                "L5",
                "L6"
            ],
            "description": "Strongest lawful claim class the export packet permits downstream."
        },
        "legal_posture": {
            "type": "string",
            "const": "Read-side Language Kernel export only. No canon authority. Not structural truth. Not primary retention substance.",
            "description": "Fixed non-authority and non-substrate posture for the export receipt."
        },
        "allowed_uses": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Bounded downstream uses allowed for the exported material.",
            "items": {
                "type": "string",
                "enum": [
                    "support_review",
                    "memory_class_probe",
                    "review_classification",
                    "advisory_readiness_probe",
                    "reasoning_overlay_benchmark"
                ]
            }
        },
        "export_scope": {
            "type": "string",
            "enum": [
                "full_packet",
                "bounded_subset",
                "single_family_subset",
                "single_object_subset"
            ],
            "description": "Scope posture of the export."
        },
        "source_family": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Optional family label constraining the export."
        },
        "row_count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100000,
            "description": "Number of exported rows included in the packet. May be 0 when export is blocked before row emission."
        },
        "object_handles": {
            "type": "array",
            "minItems": 0,
            "maxItems": 100000,
            "uniqueItems": true,
            "description": "Exact exported object handles exposed to the Language Kernel. This may be empty when export is blocked before exposure.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "pattern": "^[A-Z]{2,6}:[A-Za-z0-9._:-]+$"
            }
        },
        "receipt_hashes": {
            "type": "array",
            "minItems": 0,
            "maxItems": 100000,
            "uniqueItems": true,
            "description": "Exact provenance receipt hashes exposed through the export packet. This may be empty when export is blocked before exposure.",
            "items": {
                "type": "string",
                "minLength": 16,
                "maxLength": 128,
                "pattern": "^[A-Fa-f0-9]{16,128}$"
            }
        },
        "export_hash": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "Optional SHA-256 hash of the serialized export packet."
        },
        "non_claims": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Explicit non-claims attached to the export receipt.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
            }
        },
        "omitted_material": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "description": "Optional bounded notes describing structural material intentionally not exported.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "summary_counts": {
            "$ref": "#/$defs/summaryCounts"
        },
        "overall_status": {
            "type": "string",
            "enum": [
                "exported",
                "narrowed",
                "blocked"
            ],
            "description": "Overall export posture. 'narrowed' indicates a lawful bounded subset. 'blocked' indicates export did not complete lawfully."
        },
        "block_reasons": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Optional reasons the export was blocked or significantly narrowed.",
            "items": {
                "type": "string",
                "enum": [
                    "missing_source",
                    "hash_failure",
                    "unsupported_tier",
                    "unsupported_query_class",
                    "claim_ceiling_conflict",
                    "empty_row_set",
                    "export_policy_block",
                    "other"
                ]
            }
        },
        "export_notes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "description": "Optional bounded exporter notes.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "exported_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the export receipt was finalized."
        }
    },
    "$defs": {
        "summaryCounts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "rows_exported": {
                    "type": "integer",
                    "minimum": 0
                },
                "distinct_handles": {
                    "type": "integer",
                    "minimum": 0
                },
                "distinct_receipts": {
                    "type": "integer",
                    "minimum": 0
                },
                "anomaly_rows": {
                    "type": "integer",
                    "minimum": 0
                },
                "omitted_rows": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q3"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L1",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q4"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L2",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q6"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q7"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "const": "L6"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "overall_status": {
                        "const": "blocked"
                    }
                },
                "required": [
                    "overall_status"
                ]
            },
            "then": {
                "required": [
                    "block_reasons"
                ]
            }
        }
    ],
    "examples": [
        {
            "export_receipt_id": "ER:run_1775479542686:001",
            "exporter_version": "v0.1",
            "kernel_contract_version": "v0.1",
            "export_packet_id": "EK:run_1775479542686:v1",
            "source_run_id": "run_1775479542686",
            "source_csv_path": "exports/run_1775479542686.csv",
            "source_csv_sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
            "declared_lens": "medium FFT / Hann baseline",
            "support_tier": "RETAINED_ONLY",
            "query_class": "Q3",
            "claim_class_ceiling": "L1",
            "legal_posture": "Read-side Language Kernel export only. No canon authority. Not structural truth. Not primary retention substance.",
            "allowed_uses": [
                "support_review",
                "reasoning_overlay_benchmark"
            ],
            "export_scope": "bounded_subset",
            "source_family": "continuity_break",
            "row_count": 3,
            "object_handles": [
                "RET:1775479542686:4MI-1",
                "SPC:1775479542686:8HI",
                "AN:1775479542686:01"
            ],
            "receipt_hashes": [
                "aabbccddeeff00112233445566778899",
                "11223344556677889900aabbccddeeff",
                "cafebabefeed00112233445566778899"
            ],
            "export_hash": "89abcdef0123456789abcdef0123456789abcdef0123456789abcdef01234567",
            "non_claims": [
                "not canon",
                "not source restoration",
                "not identity proof",
                "not primary memory substrate"
            ],
            "summary_counts": {
                "rows_exported": 3,
                "distinct_handles": 3,
                "distinct_receipts": 3,
                "anomaly_rows": 1,
                "omitted_rows": 0
            },
            "overall_status": "exported",
            "exported_at": "2026-04-06T12:00:00Z"
        }
    ]
}
