                    ],
                    "reasoning_overlay": "This frame remains grounded in the listed retained and upstream handles only and does not assert stronger continuity than the exported support permits.",
                    "what_next": "Await explicit operator request for next recursion turn or new retained signature reference."
                }
            ],
            "run_metrics": {
                "structural_fidelity_score": 0.98,
                "provenance_trace_completeness": 1,
                "anomaly_propagation_fidelity": 0.95,
                "loss_gradient_honesty": 0.99,
                "continuity_badge_accuracy": 1,
                "claim_ceiling_adherence": 1,
                "recursion_explicitness_score": 1,
                "stack_purity_score": 0.97,
                "identity_trace_completeness": 1,
                "overall_status": "valid"
            },
            "validation_receipt": {
                "validation_receipt_id": "VR:run_1775479542686:001",
                "validator_version": "v0.1",
                "validation_scope": "full_kernel_run",
                "checked_artifacts": {
                    "kernel_run_id": "KR:run_1775479542686:001",
                    "export_packet_id": "EK:run_1775479542686:v1",
                    "prompt_receipt_id": "PR:run_1775479542686:001",
                    "response_receipt_id": "RR:run_1775479542686:001",
                    "frame_ids": [
