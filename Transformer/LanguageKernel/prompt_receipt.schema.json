{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dme/language-kernel/prompt_receipt.schema.json",
    "title": "DME Language Kernel Prompt Receipt v0",
    "description": "Schema for a bounded prompt receipt recording the exact invocation posture given to a Language Kernel model call. This receipt captures prompt-side lawfulness and invocation context only. It carries no structural, memory, identity, canon, or truth authority by itself.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "prompt_receipt_id",
        "invoker_version",
        "kernel_contract_version",
        "export_packet_id",
        "kernel_run_id",
        "provider",
        "model_name",
        "declared_lens",
        "query_class",
        "claim_class_ceiling",
        "operator_mode",
        "legal_claim_string",
        "what_next_string",
        "legal_posture",
        "prompt_status",
        "invoked_at"
    ],
    "properties": {
        "prompt_receipt_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^PR:[A-Za-z0-9._:-]+$",
            "description": "Unique identifier for this prompt receipt."
        },
        "invoker_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the invoker or caller that assembled and submitted the prompt."
        },
        "kernel_contract_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the Language Kernel contract governing this prompt receipt."
        },
        "export_packet_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^EK:[A-Za-z0-9._:-]+$",
            "description": "Identifier of the export packet the prompt was allowed to reference."
        },
        "kernel_run_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^KR:[A-Za-z0-9._:-]+$",
            "description": "Kernel run id this prompt receipt belongs to."
        },
        "provider": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "Model provider, for example ollama."
        },
        "model_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Model name targeted by the invocation."
        },
        "model_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Optional explicit model version string."
        },
        "declared_lens": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "description": "Declared structural lens under which the prompt must remain grounded."
        },
        "query_class": {
            "type": "string",
            "enum": [
                "Q3",
                "Q4",
                "Q6",
                "Q7"
            ],
            "description": "Active bounded query class used to assemble the prompt."
        },
        "claim_class_ceiling": {
            "type": "string",
            "enum": [
                "L1",
                "L2",
                "L4",
                "L5",
                "L6"
            ],
            "description": "Strongest lawful claim class the prompt permits."
        },
        "operator_mode": {
            "type": "string",
            "enum": [
                "explicit_only"
            ],
            "description": "Recursion control posture used in the prompt. v0 permits explicit-only progression only."
        },
        "legal_claim_string": {
            "type": "string",
            "const": "Bounded interpretation overlay only. No canon authority. Not structural truth. Read-side recursion experiment.",
            "description": "Fixed legal claim string the model is instructed to preserve in every frame."
        },
        "what_next_string": {
            "type": "string",
            "const": "Await explicit operator request for next recursion turn or new retained signature reference.",
            "description": "Fixed recursion-explicitness string the model is instructed to preserve in every frame."
        },
        "system_prompt_hash_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "Optional SHA-256 hash of the system prompt block if separated from the full assembled prompt."
        },
        "user_prompt_hash_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "Optional SHA-256 hash of the user prompt block if separated from the full assembled prompt."
        },
        "prompt_hash_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "SHA-256 hash of the fully assembled prompt submitted to the model."
        },
        "prompt_token_estimate": {
            "type": "integer",
            "minimum": 0,
            "description": "Optional token estimate for the submitted prompt."
        },
        "sampling_config": {
            "$ref": "#/$defs/samplingConfig"
        },
        "allowed_reference_scope": {
            "type": "string",
            "enum": [
                "export_packet_only"
            ],
            "default": "export_packet_only",
            "description": "Reference boundary the model is allowed to use. v0 is export-packet-only."
        },
        "allowed_frame_types": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {
                "type": "string",
                "enum": [
                    "reasoning_overlay"
                ]
            },
            "description": "Allowed frame types the prompt may request. v0 remains narrowly bounded to reasoning_overlay only."
        },
        "allowed_uses": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Bounded uses the prompt is allowed to activate.",
            "items": {
                "type": "string",
                "enum": [
                    "support_review",
                    "memory_class_probe",
                    "review_classification",
                    "advisory_readiness_probe",
                    "reasoning_overlay_benchmark"
                ]
            }
        },
        "non_claims": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Explicit non-claims baked into the prompt posture.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
            }
        },
        "prompt_flags": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Optional flags describing how the prompt was assembled or constrained.",
            "items": {
                "type": "string",
                "enum": [
                    "json_only",
                    "explicit_recursion_only",
                    "fixed_legal_claim",
                    "fixed_what_next",
                    "no_graph_reasoning",
                    "no_authority_inflation",
                    "bounded_export_only"
                ]
            }
        },
        "legal_posture": {
            "type": "string",
            "const": "Read-side Language Kernel prompt only. No canon authority. Not structural truth. Not primary retention substance.",
            "description": "Fixed non-authority and non-substrate posture for the prompt receipt."
        },
        "prompt_status": {
            "type": "string",
            "enum": [
                "assembled",
                "submitted",
                "blocked"
            ],
            "description": "Prompt lifecycle posture captured by this receipt."
        },
        "block_reasons": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Optional reasons prompt submission was blocked or not completed lawfully.",
            "items": {
                "type": "string",
                "enum": [
                    "missing_export_packet",
                    "unsupported_query_class",
                    "claim_ceiling_conflict",
                    "prompt_hash_failure",
                    "provider_unavailable",
                    "policy_block",
                    "other"
                ]
            }
        },
        "prompt_notes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "description": "Optional bounded notes about prompt assembly or invocation posture.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "invoked_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the prompt was submitted or finalized as blocked."
        }
    },
    "$defs": {
        "samplingConfig": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 2
                },
                "top_p": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "top_k": {
                    "type": "integer",
                    "minimum": 0
                },
                "repeat_penalty": {
                    "type": "number",
                    "minimum": 0
                },
                "seed": {
                    "type": "integer"
                },
                "max_tokens": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q3"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L1",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q4"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L2",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q6"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q7"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "const": "L6"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "prompt_status": {
                        "enum": [
                            "assembled",
                            "submitted"
                        ]
                    }
                },
                "required": [
                    "prompt_status"
                ]
            },
            "then": {
                "required": [
                    "prompt_hash_sha256"
                ]
            }
        },
        {
            "if": {
                "properties": {
                    "prompt_status": {
                        "const": "blocked"
                    }
                },
                "required": [
                    "prompt_status"
                ]
            },
            "then": {
                "required": [
                    "block_reasons"
                ]
            }
        }
    ],
    "examples": [
        {
            "prompt_receipt_id": "PR:run_1775479542686:001",
            "invoker_version": "v0.1",
            "kernel_contract_version": "v0.1",
            "export_packet_id": "EK:run_1775479542686:v1",
            "kernel_run_id": "KR:run_1775479542686:001",
            "provider": "ollama",
            "model_name": "llama3.1",
            "declared_lens": "medium FFT / Hann baseline",
            "query_class": "Q3",
            "claim_class_ceiling": "L1",
            "operator_mode": "explicit_only",
            "legal_claim_string": "Bounded interpretation overlay only. No canon authority. Not structural truth. Read-side recursion experiment.",
            "what_next_string": "Await explicit operator request for next recursion turn or new retained signature reference.",
            "prompt_hash_sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
            "sampling_config": {
                "temperature": 0.2,
                "top_p": 0.9,
                "max_tokens": 1200
            },
            "allowed_reference_scope": "export_packet_only",
            "allowed_frame_types": [
                "reasoning_overlay"
            ],
            "allowed_uses": [
                "support_review",
                "reasoning_overlay_benchmark"
            ],
            "non_claims": [
                "not canon",
                "not identity proof",
                "not primary memory substrate"
            ],
            "prompt_flags": [
                "json_only",
                "explicit_recursion_only",
                "fixed_legal_claim",
                "fixed_what_next",
                "bounded_export_only",
                "no_authority_inflation"
            ],
            "legal_posture": "Read-side Language Kernel prompt only. No canon authority. Not structural truth. Not primary retention substance.",
            "prompt_status": "submitted",
            "invoked_at": "2026-04-06T12:00:10Z"
        }
    ]
}
