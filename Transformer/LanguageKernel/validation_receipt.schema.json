{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dme/language-kernel/validation_receipt.schema.json",
    "title": "DME Language Kernel Validation Receipt v0",
    "description": "Schema for a bounded validation receipt produced after checking a Language Kernel run against its contract, schemas, and recursion invariants. This receipt is a review/validation artifact only. It carries no canon, truth, identity, or mechanized memory authority by itself.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "validation_receipt_id",
        "validator_version",
        "validation_scope",
        "checked_artifacts",
        "invariant_results",
        "passed_invariants",
        "violations",
        "overall_status"
    ],
    "properties": {
        "validation_receipt_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^VR:[A-Za-z0-9._:-]+$",
            "description": "Unique identifier for this validation receipt."
        },
        "validator_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the validator that produced this receipt."
        },
        "validation_scope": {
            "type": "string",
            "enum": [
                "frame_only",
                "run_envelope",
                "full_kernel_run"
            ],
            "description": "Scope of validation performed for this receipt."
        },
        "checked_artifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "kernel_run_id",
                "export_packet_id"
            ],
            "properties": {
                "kernel_run_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^KR:[A-Za-z0-9._:-]+$",
                    "description": "Kernel run id this receipt applies to."
                },
                "export_packet_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^EK:[A-Za-z0-9._:-]+$",
                    "description": "Export packet id checked during validation."
                },
                "prompt_receipt_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^PR:[A-Za-z0-9._:-]+$",
                    "description": "Optional prompt receipt id checked during validation."
                },
                "response_receipt_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^RR:[A-Za-z0-9._:-]+$",
                    "description": "Optional response receipt id checked during validation."
                },
                "frame_ids": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 512,
                    "uniqueItems": true,
                    "description": "Optional list of specific frame ids checked by this receipt.",
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 128,
                        "pattern": "^LF:[A-Za-z0-9._:-]+$"
                    }
                }
            }
        },
        "invariant_results": {
            "type": "array",
            "minItems": 5,
            "maxItems": 16,
            "description": "Per-invariant validation results for the active Language Kernel contract.",
            "items": {
                "$ref": "#/$defs/invariantResult"
            }
        },
        "passed_invariants": {
            "type": "array",
            "minItems": 0,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Names of invariants that passed cleanly.",
            "items": {
                "type": "string",
                "enum": [
                    "identity",
                    "provenance",
                    "explicit_recursion",
                    "continuity_loss",
                    "geometric_alignment"
                ]
            }
        },
        "violations": {
            "type": "array",
            "minItems": 0,
            "maxItems": 512,
            "description": "Explicit violations discovered during validation.",
            "items": {
                "$ref": "#/$defs/violation"
            }
        },
        "summary_counts": {
            "$ref": "#/$defs/summaryCounts"
        },
        "overall_status": {
            "type": "string",
            "enum": [
                "valid",
                "downgraded",
                "aborted"
            ],
            "description": "Overall validation posture for the checked object set."
        },
        "downgrade_posture": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Optional explicit downgrade posture when the run remains inspectable but not fully valid.",
            "items": {
                "type": "string",
                "enum": [
                    "support_only",
                    "continuity_drift",
                    "claim_ceiling_breach",
                    "mechanization_uncertainty",
                    "unsupported_reference",
                    "frame_rejection",
                    "run_abort"
                ]
            }
        },
        "validator_notes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "description": "Optional bounded notes from the validator. Not a substitute for explicit violations.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "validated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when validation completed."
        }
    },
    "$defs": {
        "invariantResult": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "invariant_name",
                "status",
                "score"
            ],
            "properties": {
                "invariant_name": {
                    "type": "string",
                    "enum": [
                        "identity",
                        "provenance",
                        "explicit_recursion",
                        "continuity_loss",
                        "geometric_alignment"
                    ],
                    "description": "Name of the Language Kernel invariant checked."
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "pass",
                        "downgraded",
                        "fail"
                    ],
                    "description": "Validation result for this invariant."
                },
                "score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Numeric score for this invariant."
                },
                "checked_frames": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 512,
                    "uniqueItems": true,
                    "description": "Optional frame ids directly checked for this invariant.",
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 128,
                        "pattern": "^LF:[A-Za-z0-9._:-]+$"
                    }
                },
                "notes": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 16,
                    "description": "Optional bounded notes for this invariant result.",
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 240
                    }
                }
            }
        },
        "violation": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "violation_id",
                "violation_class",
                "severity",
                "message"
            ],
            "properties": {
                "violation_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^VV:[A-Za-z0-9._:-]+$",
                    "description": "Unique identifier for this violation object."
                },
                "violation_class": {
                    "type": "string",
                    "enum": [
                        "schema_error",
                        "unsupported_reference",
                        "identity_loss",
                        "authority_bleed",
                        "claim_ceiling_breach",
                        "continuity_smoothing",
                        "graph_collapse",
                        "missing_legal_claim",
                        "explicit_recursion_breach",
                        "mechanization_gap",
                        "other"
                    ],
                    "description": "Class of validation violation."
                },
                "severity": {
                    "type": "string",
                    "enum": [
                        "info",
                        "warning",
                        "error",
                        "fatal"
                    ],
                    "description": "Severity of the violation."
                },
                "frame_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^LF:[A-Za-z0-9._:-]+$",
                    "description": "Optional frame id if the violation is frame-local."
                },
                "source_handle": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[A-Z]{2,6}:[A-Za-z0-9._:-]+$",
                    "description": "Optional source handle associated with the violation."
                },
                "message": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512,
                    "description": "Human-readable bounded explanation of the violation."
                },
                "expected": {
                    "type": [
                        "string",
                        "number",
                        "boolean"
                    ],
                    "description": "Optional expected value or posture."
                },
                "observed": {
                    "type": [
                        "string",
                        "number",
                        "boolean"
                    ],
                    "description": "Optional observed value or posture."
                },
                "suggested_posture": {
                    "type": "string",
                    "enum": [
                        "keep_valid",
                        "downgrade",
                        "reject_frame",
                        "abort_run"
                    ],
                    "description": "Suggested handling posture for the violation."
                }
            }
        },
        "summaryCounts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "frames_checked": {
                    "type": "integer",
                    "minimum": 0
                },
                "invariants_checked": {
                    "type": "integer",
                    "minimum": 0
                },
                "violations_total": {
                    "type": "integer",
                    "minimum": 0
                },
                "fatal_violations": {
                    "type": "integer",
                    "minimum": 0
                },
                "downgraded_invariants": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "overall_status": {
                        "const": "valid"
                    }
                },
                "required": [
                    "overall_status"
                ]
            },
            "then": {
                "properties": {
                    "downgrade_posture": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "overall_status": {
                        "const": "aborted"
                    }
                },
                "required": [
                    "overall_status"
                ]
            },
            "then": {
                "properties": {
                    "downgrade_posture": {
                        "contains": {
                            "const": "run_abort"
                        }
                    }
                }
            }
        }
    ],
    "examples": [
        {
            "validation_receipt_id": "VR:run_1775479542686:001",
            "validator_version": "v0.1",
            "validation_scope": "full_kernel_run",
            "checked_artifacts": {
                "kernel_run_id": "KR:run_1775479542686:001",
                "export_packet_id": "EK:run_1775479542686:v1",
                "prompt_receipt_id": "PR:run_1775479542686:001",
                "response_receipt_id": "RR:run_1775479542686:001",
                "frame_ids": [
                    "LF:run_1775479542686:0001"
                ]
            },
            "invariant_results": [
                {
                    "invariant_name": "identity",
                    "status": "pass",
                    "score": 1,
                    "checked_frames": [
                        "LF:run_1775479542686:0001"
                    ]
                },
                {
                    "invariant_name": "provenance",
                    "status": "pass",
                    "score": 1
                },
                {
                    "invariant_name": "explicit_recursion",
                    "status": "pass",
                    "score": 1
                },
                {
                    "invariant_name": "continuity_loss",
                    "status": "pass",
                    "score": 0.99
                },
                {
                    "invariant_name": "geometric_alignment",
                    "status": "pass",
                    "score": 0.97
                }
            ],
            "passed_invariants": [
                "identity",
                "provenance",
                "explicit_recursion",
                "continuity_loss",
                "geometric_alignment"
            ],
            "violations": [],
            "summary_counts": {
                "frames_checked": 1,
                "invariants_checked": 5,
                "violations_total": 0,
                "fatal_violations": 0,
                "downgraded_invariants": 0
            },
            "overall_status": "valid",
            "validated_at": "2026-04-06T12:00:12Z"
        }
    ]
}
