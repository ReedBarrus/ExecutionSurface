{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dme/language-kernel/language_overlay_export.schema.json",
    "title": "DME Language Kernel Export Packet v0",
    "description": "Schema for the bounded export packet the DME Language Kernel is allowed to read. This packet is an observational/export boundary for a read-side overlay experiment only and does not itself mint memory, identity, canon, or truth authority.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "export_packet_id",
        "kernel_contract_version",
        "source_run_id",
        "source_csv_path",
        "source_csv_sha256",
        "declared_lens",
        "support_tier",
        "query_class",
        "claim_class_ceiling",
        "legal_posture",
        "allowed_uses",
        "non_claims",
        "rows"
    ],
    "properties": {
        "export_packet_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^EK:[A-Za-z0-9._:-]+$",
            "description": "Unique identifier for the Language Kernel export packet."
        },
        "kernel_contract_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the Language Kernel contract this export packet was generated under."
        },
        "source_run_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Identifier for the source run from which retained rows were exported."
        },
        "source_csv_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024,
            "description": "Path to the source csv used to generate this bounded export packet."
        },
        "source_csv_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "SHA-256 hash of the source csv used for the export packet."
        },
        "source_jsonl_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024,
            "description": "Optional path to a companion jsonl export if present."
        },
        "source_jsonl_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "Optional SHA-256 hash of the companion jsonl export if present."
        },
        "declared_lens": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "description": "Declared structural lens under which the export packet may be interpreted."
        },
        "support_tier": {
            "type": "string",
            "enum": [
                "Tier 0 live runtime",
                "RETAINED_ONLY",
                "INSUFFICIENT_TIER"
            ],
            "description": "Support-tier posture for the export packet as a whole."
        },
        "query_class": {
            "type": "string",
            "enum": [
                "Q3",
                "Q4",
                "Q6",
                "Q7"
            ],
            "description": "Active bounded query class that constrains this export packet."
        },
        "claim_class_ceiling": {
            "type": "string",
            "enum": [
                "L1",
                "L2",
                "L4",
                "L5",
                "L6"
            ],
            "description": "Strongest lawful claim class this export packet permits downstream frames to express."
        },
        "legal_posture": {
            "type": "string",
            "const": "Read-side Language Kernel export only. No canon authority. Not structural truth. Not primary retention substance.",
            "description": "Fixed non-authority and non-substrate posture for the export packet."
        },
        "allowed_uses": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Bounded downstream uses allowed for this export packet.",
            "items": {
                "type": "string",
                "enum": [
                    "support_review",
                    "memory_class_probe",
                    "review_classification",
                    "advisory_readiness_probe",
                    "reasoning_overlay_benchmark"
                ]
            }
        },
        "non_claims": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Explicit claims this export packet does not justify.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
            }
        },
        "export_notes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "description": "Optional bounded notes about how the export packet was produced.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "rows": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2048,
            "description": "Bounded exported row set the Language Kernel is allowed to inspect.",
            "items": {
                "$ref": "#/$defs/exportRow"
            }
        }
    },
    "$defs": {
        "exportRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "object_handle",
                "provenance_receipt_hash",
                "artifact_class",
                "continuity_status",
                "structural_loss_percent",
                "allowed_use",
                "non_claims"
            ],
            "properties": {
                "object_handle": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[A-Z]{2,6}:[A-Za-z0-9._:-]+$",
                    "description": "Exact exported object handle."
                },
                "provenance_receipt_hash": {
                    "type": "string",
                    "minLength": 16,
                    "maxLength": 128,
                    "pattern": "^[A-Fa-f0-9]{16,128}$",
                    "description": "Receipt hash or bounded provenance hash for this exported row."
                },
                "artifact_class": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64,
                    "description": "Artifact class of the exported row, for example RET, MI, HI, An, or related bounded retained class labels."
                },
                "t_start": {
                    "type": "number",
                    "description": "Optional bounded start time or index for this row."
                },
                "t_end": {
                    "type": "number",
                    "description": "Optional bounded end time or index for this row."
                },
                "continuity_status": {
                    "type": "string",
                    "enum": [
                        "Stable",
                        "Drifting",
                        "Broken",
                        "Recurring"
                    ],
                    "description": "Continuity posture exported for this bounded row."
                },
                "structural_loss_percent": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "multipleOf": 0.01,
                    "description": "Structural loss percentage exported for this bounded row."
                },
                "anomaly_flags": {
                    "type": "array",
                    "description": "Optional anomaly flags preserved from the export source.",
                    "minItems": 1,
                    "maxItems": 32,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 64
                    }
                },
                "upstream_handles": {
                    "type": "array",
                    "description": "Optional exact upstream object handles used to preserve bounded lineage for this exported row.",
                    "minItems": 1,
                    "maxItems": 32,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 256,
                        "pattern": "^[A-Z]{2,6}:[A-Za-z0-9._:-]+$"
                    }
                },
                "descriptor_vector": {
                    "type": "object",
                    "additionalProperties": {
                        "type": [
                            "string",
                            "number",
                            "boolean"
                        ]
                    },
                    "description": "Optional sparse descriptor-backed structural fields exposed for bounded overlay use."
                },
                "allowed_use": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 16,
                    "uniqueItems": true,
                    "description": "Bounded uses allowed for this specific row.",
                    "items": {
                        "type": "string",
                        "enum": [
                            "support_review",
                            "memory_class_probe",
                            "review_classification",
                            "advisory_readiness_probe",
                            "reasoning_overlay_benchmark"
                        ]
                    }
                },
                "non_claims": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 16,
                    "uniqueItems": true,
                    "description": "Explicit denials attached to this row to prevent over-reading.",
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 160
                    }
                },
                "source_row_index": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Optional original row index in the source csv."
                },
                "source_family": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "description": "Optional bounded family label for same-family constraints."
                }
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q3"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L1",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q4"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L2",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q6"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q7"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "const": "L6"
                    }
                }
            }
        }
    ],
    "examples": [
        {
            "export_packet_id": "EK:run_1775479542686:v1",
            "kernel_contract_version": "v0.1",
            "source_run_id": "run_1775479542686",
            "source_csv_path": "exports/run_1775479542686.csv",
            "source_csv_sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
            "declared_lens": "medium FFT / Hann baseline",
            "support_tier": "RETAINED_ONLY",
            "query_class": "Q3",
            "claim_class_ceiling": "L1",
            "legal_posture": "Read-side Language Kernel export only. No canon authority. Not structural truth. Not primary retention substance.",
            "allowed_uses": [
                "support_review",
                "reasoning_overlay_benchmark"
            ],
            "non_claims": [
                "not canon",
                "not source restoration",
                "not identity proof",
                "not primary memory substrate"
            ],
            "rows": [
                {
                    "object_handle": "RET:1775479542686:4MI-1",
                    "provenance_receipt_hash": "aabbccddeeff00112233445566778899",
                    "artifact_class": "RET",
                    "t_start": 1.25,
                    "t_end": 1.5,
                    "continuity_status": "Stable",
                    "structural_loss_percent": 12.5,
                    "anomaly_flags": [
                        "continuity_break"
                    ],
                    "upstream_handles": [
                        "SPC:1775479542686:8HI"
                    ],
                    "descriptor_vector": {
                        "band_profile_shift": 0.18,
                        "support_strength": "moderate"
                    },
                    "allowed_use": [
                        "support_review",
                        "reasoning_overlay_benchmark"
                    ],
                    "non_claims": [
                        "not canon",
                        "not source restoration"
                    ],
                    "source_row_index": 4,
                    "source_family": "continuity_break"
                }
            ]
        }
    ]
}
