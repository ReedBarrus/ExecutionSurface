{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dme/language-kernel/response_receipt.schema.json",
    "title": "DME Language Kernel Response Receipt v0",
    "description": "Schema for a bounded response receipt recording what the model actually returned before full validation closure. This receipt captures raw-return posture, parse posture, and immediate response-side accounting only. It carries no structural, memory, identity, canon, or truth authority by itself.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "response_receipt_id",
        "receiver_version",
        "kernel_contract_version",
        "kernel_run_id",
        "export_packet_id",
        "prompt_receipt_id",
        "provider",
        "model_name",
        "declared_lens",
        "query_class",
        "claim_class_ceiling",
        "legal_posture",
        "response_status",
        "parse_status",
        "schema_status",
        "frame_count",
        "received_at"
    ],
    "properties": {
        "response_receipt_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^RR:[A-Za-z0-9._:-]+$",
            "description": "Unique identifier for this response receipt."
        },
        "receiver_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the receiver/parser that captured this response."
        },
        "kernel_contract_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$",
            "description": "Version of the Language Kernel contract governing this response."
        },
        "kernel_run_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^KR:[A-Za-z0-9._:-]+$",
            "description": "Kernel run id this response belongs to."
        },
        "export_packet_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^EK:[A-Za-z0-9._:-]+$",
            "description": "Export packet id this response was generated against."
        },
        "prompt_receipt_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^PR:[A-Za-z0-9._:-]+$",
            "description": "Prompt receipt id this response answers."
        },
        "provider": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "Model provider, for example ollama."
        },
        "model_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Model name that produced the response."
        },
        "model_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Optional explicit model version string."
        },
        "declared_lens": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "description": "Declared structural lens the response is expected to remain grounded in."
        },
        "query_class": {
            "type": "string",
            "enum": [
                "Q3",
                "Q4",
                "Q6",
                "Q7"
            ],
            "description": "Active bounded query class for the response."
        },
        "claim_class_ceiling": {
            "type": "string",
            "enum": [
                "L1",
                "L2",
                "L4",
                "L5",
                "L6"
            ],
            "description": "Strongest lawful claim class the response was allowed to express."
        },
        "legal_posture": {
            "type": "string",
            "const": "Read-side Language Kernel response only. No canon authority. Not structural truth. Not primary retention substance.",
            "description": "Fixed non-authority and non-substrate posture for the response receipt."
        },
        "raw_response_hash_sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$",
            "description": "SHA-256 hash of the raw model response exactly as received."
        },
        "raw_response_bytes": {
            "type": "integer",
            "minimum": 0,
            "description": "Optional size of the raw response in bytes."
        },
        "response_token_estimate": {
            "type": "integer",
            "minimum": 0,
            "description": "Optional token estimate for the received response."
        },
        "response_status": {
            "type": "string",
            "enum": [
                "received",
                "empty",
                "refused",
                "truncated",
                "blocked"
            ],
            "description": "Immediate response-side posture before validation closure."
        },
        "parse_status": {
            "type": "string",
            "enum": [
                "parsed",
                "json_error",
                "partial_json",
                "non_json",
                "not_attempted"
            ],
            "description": "Result of attempting to parse the raw response into JSON."
        },
        "schema_status": {
            "type": "string",
            "enum": [
                "conformant",
                "nonconformant",
                "not_checked"
            ],
            "description": "Immediate schema-level posture before full validation receipt closure."
        },
        "frame_count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 512,
            "description": "Number of extracted language frames from the parsed response."
        },
        "frame_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 512,
            "uniqueItems": true,
            "description": "Optional extracted frame ids when parsing succeeds.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128,
                "pattern": "^LF:[A-Za-z0-9._:-]+$"
            }
        },
        "legal_claim_present": {
            "type": "boolean",
            "description": "Whether the fixed legal claim string was detected in all extracted frames at the receiver layer."
        },
        "what_next_present": {
            "type": "boolean",
            "description": "Whether the fixed explicit-recursion what_next string was detected in all extracted frames at the receiver layer."
        },
        "unsupported_reference_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Optional immediate count of detected unsupported references before full validation."
        },
        "conformance_outcome": {
            "type": "string",
            "enum": [
                "contract_conformant",
                "downgraded_conformance_gap",
                "aborted_contract_failure",
                "aborted_empty_first_turn_output",
                "aborted_empty_first_turn_frame_list",
                "aborted_nested_wrong_shape_output",
                "aborted_metadata_summary_pseudo_frame",
                "aborted_extra_prose_leakage",
                "aborted_fixed_string_failure",
                "downgraded_partial_frame_conformance",
                "downgraded_near_valid_incomplete_frame"
            ],
            "description": "Normalized conformance outcome for current local-model first-turn testing. This is an audit/evaluation label only, not an authority uplift."
        },
        "receiver_flags": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "description": "Optional response-side flags recorded by the receiver.",
            "items": {
                "type": "string",
                "enum": [
                    "json_only_expected",
                    "parsed_cleanly",
                    "schema_checked",
                    "legal_claim_missing",
                    "what_next_missing",
                    "possible_truncation",
                    "possible_refusal",
                    "possible_authority_bleed",
                    "possible_graph_collapse",
                    "unsupported_references_detected",
                    "extra_prose_leakage",
                    "empty_first_turn_frame_list",
                    "nested_wrong_shape_output",
                    "metadata_summary_pseudo_frame",
                    "fixed_string_failure",
                    "partial_frame_conformance",
                    "near_valid_incomplete_frame"
                ]
            }
        },
        "refusal_reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "description": "Optional refusal or block reason returned or inferred at the receiver layer."
        },
        "receiver_notes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "description": "Optional bounded notes about response capture or parsing posture.",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "received_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the response was captured."
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q3"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L1",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q4"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L2",
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q6"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "enum": [
                            "L4",
                            "L5"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "query_class": {
                        "const": "Q7"
                    }
                },
                "required": [
                    "query_class"
                ]
            },
            "then": {
                "properties": {
                    "claim_class_ceiling": {
                        "const": "L6"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "response_status": {
                        "enum": [
                            "received",
                            "empty",
                            "refused",
                            "truncated"
                        ]
                    }
                },
                "required": [
                    "response_status"
                ]
            },
            "then": {
                "required": [
                    "raw_response_hash_sha256"
                ]
            }
        },
        {
            "if": {
                "properties": {
                    "response_status": {
                        "const": "received"
                    }
                },
                "required": [
                    "response_status"
                ]
            },
            "then": {
                "properties": {
                    "parse_status": {
                        "not": {
                            "const": "non_json"
                        }
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "parse_status": {
                        "const": "parsed"
                    }
                },
                "required": [
                    "parse_status"
                ]
            },
            "then": {
                "properties": {
                    "frame_count": {
                        "minimum": 1
                    },
                    "schema_status": {
                        "enum": [
                            "conformant",
                            "nonconformant"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "response_status": {
                        "const": "blocked"
                    }
                },
                "required": [
                    "response_status"
                ]
            },
            "then": {
                "properties": {
                    "parse_status": {
                        "const": "not_attempted"
                    },
                    "schema_status": {
                        "const": "not_checked"
                    },
                    "frame_count": {
                        "const": 0
                    },
                    "raw_response_hash_sha256": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "response_status": {
                        "enum": [
                            "refused",
                            "blocked"
                        ]
                    }
                },
                "required": [
                    "response_status"
                ]
            },
            "then": {
                "required": [
                    "refusal_reason"
                ]
            }
        }
    ],
    "examples": [
        {
            "response_receipt_id": "RR:run_1775479542686:001",
            "receiver_version": "v0.1",
            "kernel_contract_version": "v0.1",
            "kernel_run_id": "KR:run_1775479542686:001",
            "export_packet_id": "EK:run_1775479542686:v1",
            "prompt_receipt_id": "PR:run_1775479542686:001",
            "provider": "ollama",
            "model_name": "llama3.1",
            "declared_lens": "medium FFT / Hann baseline",
            "query_class": "Q3",
            "claim_class_ceiling": "L1",
            "legal_posture": "Read-side Language Kernel response only. No canon authority. Not structural truth. Not primary retention substance.",
            "raw_response_hash_sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
            "raw_response_bytes": 1842,
            "response_token_estimate": 420,
            "response_status": "received",
            "parse_status": "parsed",
            "schema_status": "conformant",
            "frame_count": 1,
            "frame_ids": [
                "LF:run_1775479542686:0001"
            ],
            "legal_claim_present": true,
            "what_next_present": true,
            "unsupported_reference_count": 0,
            "conformance_outcome": "contract_conformant",
            "receiver_flags": [
                "json_only_expected",
                "parsed_cleanly",
                "schema_checked"
            ],
            "received_at": "2026-04-06T12:00:11Z"
        }
    ]
}
