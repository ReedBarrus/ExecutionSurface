{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "dme/language-kernel/language_kernel_benchmark_run.schema.json",
    "title": "DME Language Kernel Benchmark Run v0",
    "description": "Schema for a bounded Language Kernel benchmark run/result object. This object records benchmark family, regime, source artifacts, raw metrics, derived scores, and final posture for one benchmarked loop or conversation-behavior run. It carries no canon, truth, memory, identity, or readiness authority by itself.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "benchmark_run_id",
        "benchmark_contract_version",
        "kernel_contract_version",
        "benchmark_family",
        "benchmark_tier",
        "regime",
        "source_artifacts",
        "expected_posture",
        "observed_posture",
        "raw_metrics",
        "derived_scores",
        "final_status"
    ],
    "properties": {
        "benchmark_run_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^BK:[A-Za-z0-9._:-]+$"
        },
        "benchmark_contract_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$"
        },
        "kernel_contract_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^v[0-9]+(?:\\.[0-9]+)?$"
        },
        "benchmark_family": {
            "type": "string",
            "enum": [
                "export_boundary_integrity",
                "prompt_confinement",
                "response_hygiene",
                "frame_contract_conformance",
                "invariant_preservation",
                "run_envelope_coherence",
                "thread_continuity",
                "query_preservation",
                "claim_discipline",
                "support_lineage_preservation",
                "perturbation_recovery",
                "compression_fidelity",
                "mechanization_honesty",
                "semantic_overlay_restraint"
            ]
        },
        "benchmark_tier": {
            "type": "string",
            "enum": [
                "tier_1_loop_lawfulness",
                "tier_2_conversation_behavior"
            ]
        },
        "regime": {
            "type": "string",
            "enum": [
                "stable",
                "perturbation",
                "compression",
                "boundary_shift",
                "failure"
            ]
        },
        "source_artifacts": {
            "$ref": "#/$defs/sourceArtifacts"
        },
        "expected_posture": {
            "$ref": "#/$defs/expectedObservedPosture"
        },
        "observed_posture": {
            "$ref": "#/$defs/expectedObservedPosture"
        },
        "raw_metrics": {
            "$ref": "#/$defs/rawMetrics"
        },
        "derived_scores": {
            "$ref": "#/$defs/derivedScores"
        },
        "benchmark_receipt_refs": {
            "$ref": "#/$defs/benchmarkReceiptRefs"
        },
        "panel_outcome": {
            "type": "string",
            "enum": [
                "contract_conformant",
                "downgraded_conformance_gap",
                "aborted_contract_failure",
                "aborted_empty_first_turn_output",
                "aborted_empty_first_turn_frame_list",
                "aborted_nested_wrong_shape_output",
                "aborted_metadata_summary_pseudo_frame",
                "aborted_extra_prose_leakage",
                "aborted_fixed_string_failure",
                "downgraded_partial_frame_conformance",
                "downgraded_near_valid_incomplete_frame"
            ]
        },
        "failure_notes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
            }
        },
        "downgrade_posture_required": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "uniqueItems": true,
            "items": {
                "type": "string",
                "enum": [
                    "support_only",
                    "continuity_drift",
                    "claim_ceiling_breach",
                    "mechanization_uncertainty",
                    "unsupported_reference",
                    "frame_rejection",
                    "benchmark_abort"
                ]
            }
        },
        "final_status": {
            "type": "string",
            "enum": [
                "valid",
                "narrowed",
                "downgraded",
                "aborted"
            ]
        },
        "benchmarked_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "$defs": {
        "sourceArtifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "kernel_run_id"
            ],
            "properties": {
                "kernel_run_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^KR:[A-Za-z0-9._:-]+$"
                },
                "export_packet_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^EK:[A-Za-z0-9._:-]+$"
                },
                "export_receipt_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^ER:[A-Za-z0-9._:-]+$"
                },
                "prompt_receipt_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^PR:[A-Za-z0-9._:-]+$"
                },
                "response_receipt_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^RR:[A-Za-z0-9._:-]+$"
                },
                "validation_receipt_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^VR:[A-Za-z0-9._:-]+$"
                },
                "frame_ids": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 512,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 128,
                        "pattern": "^LF:[A-Za-z0-9._:-]+$"
                    }
                }
            }
        },
        "expectedObservedPosture": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "query_class": {
                    "type": "string",
                    "enum": [
                        "Q3",
                        "Q4",
                        "Q6",
                        "Q7"
                    ]
                },
                "claim_class_ceiling": {
                    "type": "string",
                    "enum": [
                        "L1",
                        "L2",
                        "L4",
                        "L5",
                        "L6"
                    ]
                },
                "operator_mode": {
                    "type": "string",
                    "enum": [
                        "explicit_only"
                    ]
                },
                "overall_status": {
                    "type": "string",
                    "enum": [
                        "valid",
                        "narrowed",
                        "downgraded",
                        "aborted"
                    ]
                },
                "notes": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 16,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 240
                    }
                }
            }
        },
        "rawMetrics": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "export_boundary_integrity": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "row_completeness": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "prompt_boundary_adherence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "recursion_control_adherence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "parse_success_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "schema_conformance_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "exact_string_adherence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "reference_integrity": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "status_honesty": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "envelope_coherence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "receipt_chain_completeness": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "drift_coherence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "query_preservation": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "claim_discipline": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "support_anchor_stability": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "downgrade_honesty": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "perturbation_recovery": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "compression_fidelity": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "mechanization_honesty": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "semantic_overlay_restraint": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "derivedScores": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "loop_lawfulness_score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "reference_grounding_score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "recursion_discipline_score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "loss_honesty_score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "non_authority_discipline_score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            }
        },
        "benchmarkReceiptRefs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "export_receipt_id": {
                    "type": "string",
                    "pattern": "^ER:[A-Za-z0-9._:-]+$"
                },
                "prompt_receipt_id": {
                    "type": "string",
                    "pattern": "^PR:[A-Za-z0-9._:-]+$"
                },
                "response_receipt_id": {
                    "type": "string",
                    "pattern": "^RR:[A-Za-z0-9._:-]+$"
                },
                "validation_receipt_id": {
                    "type": "string",
                    "pattern": "^VR:[A-Za-z0-9._:-]+$"
                }
            }
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "benchmark_tier": {
                        "const": "tier_1_loop_lawfulness"
                    }
                },
                "required": [
                    "benchmark_tier"
                ]
            },
            "then": {
                "properties": {
                    "benchmark_family": {
                        "enum": [
                            "export_boundary_integrity",
                            "prompt_confinement",
                            "response_hygiene",
                            "frame_contract_conformance",
                            "invariant_preservation",
                            "run_envelope_coherence"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "benchmark_tier": {
                        "const": "tier_2_conversation_behavior"
                    }
                },
                "required": [
                    "benchmark_tier"
                ]
            },
            "then": {
                "properties": {
                    "benchmark_family": {
                        "enum": [
                            "thread_continuity",
                            "query_preservation",
                            "claim_discipline",
                            "support_lineage_preservation",
                            "perturbation_recovery",
                            "compression_fidelity",
                            "mechanization_honesty",
                            "semantic_overlay_restraint"
                        ]
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "final_status": {
                        "const": "valid"
                    }
                },
                "required": [
                    "final_status"
                ]
            },
            "then": {
                "properties": {
                    "downgrade_posture_required": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "final_status": {
                        "const": "aborted"
                    }
                },
                "required": [
                    "final_status"
                ]
            },
            "then": {
                "properties": {
                    "downgrade_posture_required": {
                        "contains": {
                            "const": "benchmark_abort"
                        }
                    }
                }
            }
        }
    ],
    "examples": [
        {
            "benchmark_run_id": "BK:run_1775479542686:inv-001",
            "benchmark_contract_version": "v0.1",
            "kernel_contract_version": "v0.1",
            "benchmark_family": "invariant_preservation",
            "benchmark_tier": "tier_1_loop_lawfulness",
            "regime": "perturbation",
            "source_artifacts": {
                "kernel_run_id": "KR:run_1775479542686:001",
                "export_packet_id": "EK:run_1775479542686:v1",
                "export_receipt_id": "ER:run_1775479542686:001",
                "prompt_receipt_id": "PR:run_1775479542686:001",
                "response_receipt_id": "RR:run_1775479542686:001",
                "validation_receipt_id": "VR:run_1775479542686:001",
                "frame_ids": [
                    "LF:run_1775479542686:0001"
                ]
            },
            "expected_posture": {
                "query_class": "Q3",
                "claim_class_ceiling": "L1",
                "operator_mode": "explicit_only",
                "overall_status": "valid"
            },
            "observed_posture": {
                "query_class": "Q3",
                "claim_class_ceiling": "L1",
                "operator_mode": "explicit_only",
                "overall_status": "downgraded",
                "notes": [
                    "continuity/loss invariant weakened under perturbation"
                ]
            },
            "raw_metrics": {
                "reference_integrity": 0.97,
                "status_honesty": 0.94,
                "receipt_chain_completeness": 1,
                "downgrade_honesty": 1
            },
            "derived_scores": {
                "loop_lawfulness_score": 0.95,
                "reference_grounding_score": 0.98,
                "recursion_discipline_score": 1,
                "loss_honesty_score": 0.93,
                "non_authority_discipline_score": 1
            },
            "benchmark_receipt_refs": {
                "export_receipt_id": "ER:run_1775479542686:001",
                "prompt_receipt_id": "PR:run_1775479542686:001",
                "response_receipt_id": "RR:run_1775479542686:001",
                "validation_receipt_id": "VR:run_1775479542686:001"
            },
            "panel_outcome": "downgraded_conformance_gap",
            "failure_notes": [
                "one frame softened structural loss wording while preserving explicit non-authority posture"
            ],
            "downgrade_posture_required": [
                "continuity_drift"
            ],
            "final_status": "downgraded",
            "benchmarked_at": "2026-04-06T13:00:00Z"
        }
    ]
}
