{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dme/execution-surface/handoff/pass_request.schema.json",
  "title": "Pressure Generation Pass Request",
  "description": "Bounded request envelope for one role pass over an active subject.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pass_id",
    "role",
    "active_subject_id",
    "state_before",
    "purpose",
    "scope",
    "inputs",
    "required_output_keys"
  ],
  "properties": {
    "pass_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": [
        "constructor",
        "creative",
        "reflector",
        "auditor_gate",
        "admin_router"
      ]
    },
    "active_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "state_before": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_surface_path",
        "section_anchor",
        "forbidden"
      ],
      "properties": {
        "live_surface_path": {
          "type": "string",
          "minLength": 1
        },
        "section_anchor": {
          "type": "string",
          "minLength": 1
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "inputs": {
      "type": "object"
    },
    "required_output_keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
