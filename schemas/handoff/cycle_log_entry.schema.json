{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dme/execution-surface/handoff/cycle_log_entry.schema.json",
  "title": "Morphogenesis Cycle Log Entry",
  "description": "Append-only cycle log entry for one bounded pass.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pass_id",
    "role",
    "active_subject_id",
    "state_before",
    "state_after",
    "accepted_changes",
    "rejected_changes",
    "live_tensions",
    "recommended_next_role"
  ],
  "properties": {
    "pass_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "active_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "state_before": {
      "type": "string",
      "minLength": 1
    },
    "state_after": {
      "type": "string",
      "minLength": 1
    },
    "accepted_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rejected_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "live_tensions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_next_role": {
      "type": "string",
      "minLength": 1
    }
  }
}
